<odoo>
	<record id="view_t4tek_transit_picking_type_tree" model="ir.ui.view">
		<field name="name">t4tek.transit.picking.type.tree</field>
		<field name="model">t4tek.transit.picking.type</field>
		<field name="arch" type="xml">
			<list>
				<field name="relation_type"/>
				<field name="warehouse_id"/>
				<field name="dest_picking_type_id"/>
				<field name="src_picking_type_id"/>
				<field name="company_id"/>
			</list>
		</field>
	</record>

	<record id="view_t4tek_transit_picking_type_form" model="ir.ui.view">
		<field name="name">t4tek.transit.picking.type.form</field>
		<field name="model">t4tek.transit.picking.type</field>
		<field name="arch" type="xml">
			<form class="o_t4tek_transit_picking_type">
				<sheet>
					<group>
						<div class="oe_title">
							<h1>
								<field name="company_id"/>
							</h1>
						</div>
					</group>
					<group>
						<group>
							<field name="relation_type" string="Relation Type"/>
							<field name="warehouse_id"/>
						</group>
					</group>
					<group>
						<group string="Transit Delivery Operation">
							<field name="src_picking_type_id"/>
						</group>
						<group string="Transit Receipt Operation">
							<field name="dest_picking_type_id"/>
						</group>
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="view_t4tek_transit_picking_type_search" model="ir.ui.view">
		<field name="name">t4tek.transit.picking.type.search</field>
		<field name="model">t4tek.transit.picking.type</field>
		<field name="arch" type="xml">
			<search>
				<filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
			</search>
		</field>
	</record>

	<record id="action_t4tek_transit_picking_type" model="ir.actions.act_window">
		<field name="name">Transit Operation Types</field>
		<field name="res_model">t4tek.transit.picking.type</field>
		<field name="view_mode">list,form,search</field>
		<field name="context">{"create": False, "delete": False, "edit": False}</field>
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
				Manage inter-company transit operation mappings here.
			</p>
		</field>
	</record>
</odoo>