<odoo>
	<!-- ─────────────────────────────────────────────────────────────────────
	  Color-theme legend (order line level)
	  ─────────────────────────────────────────────────────────────────────
	  decoration-warning → transit done + quantity == 0
	                        nothing received for this product  (🟡 product issue)
	  decoration-danger  → transit done + quantity > 0 but ≠ demanded
	                        received qty is wrong              (🟠 qty issue,
	                        closest Odoo list decoration to orange)
	  decoration-muted   → transit cancelled
	  ───────────────────────────────────────────────────────────────────── -->

	<record id="view_t4tek_transit_order_line_tree" model="ir.ui.view">
		<field name="name">t4tek.transit.order.line.tree</field>
		<field name="model">t4tek.transit.order.line</field>
		<field name="arch" type="xml">
			<list decoration-muted="state == 'cancel'" decoration-warning="state == 'done' and quantity == 0" decoration-danger="state == 'done' and quantity > 0 and quantity != product_uom_qty">
				<field name="state" optional="hide" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'assigned'" decoration-primary="state == 'in_progress'" decoration-success="state == 'done'" decoration-muted="state == 'cancel'"/>
				<field name="product_uom_category_id" column_invisible="1"/>
				<field name="company_id" optional="hide"/>

				<field name="product_id"/>
				<field name="name" optional="hide"/>
				<field name="note" optional="hide"/>
				<field name="product_uom_qty" string="Demand"/>
				<field name="quantity" optional="show" readonly="1" decoration-success="quantity > 0" decoration-muted="quantity == 0"/>
				<field name="product_uom" string="Unit" groups="uom.group_uom"/>
			</list>
		</field>
	</record>

	<!-- Form view for t4tek.transit.order.line (popup detail view) -->
	<record id="view_t4tek_transit_order_line_form" model="ir.ui.view">
		<field name="name">t4tek.transit.order.line.form</field>
		<field name="model">t4tek.transit.order.line</field>
		<field name="arch" type="xml">
			<form string="Transit Move">
				<sheet>
					<group>
						<group>
							<field name="product_id" context="{'default_detailed_type': 'consu'}" options="{'no_create': True}"/>
							<field name="name"/>
							<field name="product_uom_qty" decoration-info="1"/>
							<field name="product_uom" string="Unit" groups="uom.group_uom" options="{'no_create': True}"/>
							<field name="product_uom_category_id" invisible="1"/>
						</group>
						<group>
							<field name="quantity" readonly="1" decoration-success="quantity > 0 and quantity == product_uom_qty" decoration-warning="state == 'done' and quantity == 0" decoration-danger="state == 'done' and quantity > 0 and quantity != product_uom_qty"/>
							<field name="state"/>
						</group>
					</group>
					<group string="Additional Information">
						<field name="origin"/>
						<field name="company_id"/>
					</group>
					<group string="Notes">
						<field name="note" nolabel="1"/>
					</group>
				</sheet>
			</form>
		</field>
	</record>
</odoo>